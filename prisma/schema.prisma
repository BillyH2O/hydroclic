// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Paramètres boutique (singleton id = "default") — frais de livraison & seuil gratuit
model StoreSettings {
  id String @id @default("default")

  /// Panier TTC (hors livraison) à partir de ce montant (≥) : livraison gratuite. Null = pas de palier gratuit.
  freeShippingThresholdEur Float?
  /// Frais de livraison (€) si le seuil n’est pas atteint (ou si aucun seuil).
  shippingFeeEur           Float @default(0)

  updatedAt DateTime @updatedAt

  @@map("store_settings")
}

model Product {
  id          String   @id @default(uuid())
  name        String
  slug        String?  @unique // Slug URL-friendly pour le produit
  sku         String?  @unique // Stock Keeping Unit - identifiant unique du produit
  priceB2C    Float    // Prix pour les comptes particuliers (B2C)
  priceB2B    Float    // Prix pour les comptes professionnels (B2B)
  image       String   @default("/default.png")
  imageAlt    String?
  description String?
  discount    Int?     // Pourcentage de réduction (0-100)
  category    String?  // nouveaute, promotion, destockage, etc.
  productType String?  // hydrodistribution, sanitaire, etc.
  isNew        Boolean  @default(false)
  isPromotion  Boolean  @default(false)
  isDestockage Boolean  @default(false)
  ribbonText   String?  // Texte du ruban (ex: -40%, Arrivage, Quantité limitée)
  ribbonColor  String?  // Couleur du ruban (ex: red, blue, green, orange, purple)
  createdAt    DateTime @default(now())
  updatedAt   DateTime @updatedAt

  cartItems   CartItem[]
  orderItems  OrderItem[]

  @@map("products")
}

model Cart {
  id        String   @id @default(uuid())
  userId    String   // ID utilisateur Clerk
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items     CartItem[]

  @@unique([userId])
  @@map("carts")
}

model CartItem {
  id        String   @id @default(uuid())
  cartId    String
  productId String
  quantity  Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cart      Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([cartId, productId])
  @@map("cart_items")
}

model Order {
  id              String   @id @default(uuid())
  userId          String   // ID utilisateur Clerk
  stripeSessionId String?  @unique // ID de session Stripe
  status          String   @default("pending") // pending, paid, cancelled, failed
  totalAmount     Float    // Montant total en euros
  currency        String   @default("eur")
  /// home = livraison à domicile ; pickup = click & collect (dépôt Aubervilliers)
  deliveryMethod  String   @default("home")
  customerEmail   String?
  customerPhone   String?
  billingAddress  Json?    // facturation (snapshot Stripe customer_details)
  shippingAddress Json?    // livraison (snapshot Stripe) ou adresse du dépôt si pickup
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  items           OrderItem[]

  @@map("orders")
}

model OrderItem {
  id        String   @id @default(uuid())
  orderId   String
  productId String
  quantity  Int
  price     Float    // Prix unitaire au moment de la commande
  createdAt DateTime @default(now())

  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id])

  @@map("order_items")
}

/// Conversation WhatsApp (client → numéro business) pour le suivi SLA « réponse sous 1 h ».
model WhatsappConversation {
  id             String    @id @default(uuid())
  /// Identifiant WhatsApp du client (chiffres, sans +)
  customerWaId   String    @unique
  lastInboundAt  DateTime
  lastReplyAt    DateTime?
  /// Mis à jour à chaque message client (true) / réponse business (false)
  needsReply     Boolean   @default(false)
  /// Dernier délai SLA calculé (lastInboundAt + SLA)
  slaDeadlineAt  DateTime
  slaAlertSentAt DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([slaDeadlineAt])
  @@map("whatsapp_conversations")
}

/// Idempotence des webhooks WhatsApp (wamid…)
model WhatsappProcessedMessage {
  waMessageId String   @id
  createdAt   DateTime @default(now())

  @@map("whatsapp_processed_messages")
}
